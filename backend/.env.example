PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Max upload size in bytes (default 200 MB)
MAX_FILE_SIZE=209715200

# Where encrypted files are stored
STORAGE_DIR=./uploads

# SQLite database path
DB_PATH=./data/db.sqlite

# Cleanup worker interval in ms (default 60 s)
CLEANUP_INTERVAL_MS=60000

# In-memory rate limit: max requests per window
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=1 minute

# Set to true only during development — enables Fastify logger
DEV_MODE=false
